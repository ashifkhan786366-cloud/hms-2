# Hospital Management System — Git Ignore
# =========================================

# ── Sensitive Config (NEVER commit this) ──
config/db.php
accounting.config

# ── Patient Photos (Private medical data) ──
uploads/*
!uploads/.gitkeep

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── Editor Files ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── Log Files ──
*.log
error_log
/logs/

# ── PHP Cache ──
*.cache

# ── Temp Files ──
*.tmp
*.temp

# ── Environment Files ──
.env
.env.local
.env.production

# ── Composer (if added later) ──
/vendor/
composer.lock
