# Hospital Management System - Git Ignore

# Configuration files with sensitive data (db.example.php is safe to commit)
config/db.php
accounting.config

# Upload folder (patient photos - sensitive data)
uploads/*
!uploads/.gitkeep

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Editor Files
.vscode/
.idea/
*.swp
*.swo
*~

# Log Files
*.log
error_log

# PHP cache
*.cache

# Temp files
*.tmp
*.temp

# Environment files
.env
.env.local
.env.production
